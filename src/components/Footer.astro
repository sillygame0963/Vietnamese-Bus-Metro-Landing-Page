---

<section id="download" class="gradient-hero py-12 px-4 text-white">
  <div class="max-w-md mx-auto text-center">
    <h2 class="text-2xl font-bold mb-2">Sẵn sàng di chuyển?</h2>
    <p class="text-white/70 text-sm mb-6">Tải GoViet ngay — miễn phí trên iOS và Android</p>

    <div class="flex gap-3 justify-center mb-8">
      <a href="#" class="bg-white text-primary font-semibold px-5 py-3 rounded-full text-sm hover:bg-gray-100 transition-colors flex items-center gap-2">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
        </svg>
        App Store
      </a>
      <a href="#" class="bg-white/20 backdrop-blur-sm text-white font-semibold px-5 py-3 rounded-full text-sm hover:bg-white/30 transition-colors flex items-center gap-2 border border-white/30">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.198l2.807 1.626a1 1 0 010 1.73l-2.808 1.626L15.206 12l2.492-2.491zM5.864 2.658L16.802 8.99l-2.303 2.303-8.635-8.635z"/>
        </svg>
        Google Play
      </a>
    </div>

    <!-- Newsletter -->
    <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-4 mb-8">
      <p class="text-sm font-semibold mb-3">Đăng ký nhận tin sớm nhất</p>
      <div class="flex gap-2">
        <input
          type="email"
          placeholder="email@example.com"
          class="flex-1 px-4 py-2.5 rounded-full bg-white/20 border border-white/20 text-sm text-white placeholder-white/50 focus:outline-none focus:ring-2 focus:ring-white/30"
        />
        <button class="bg-white text-primary font-semibold px-4 py-2.5 rounded-full text-sm hover:bg-gray-100 transition-colors shrink-0">
          Đăng ký
        </button>
      </div>
    </div>

    <!-- Footer Links -->
    <div class="flex justify-center gap-6 text-xs text-white/50 mb-4">
      <a href="#" class="hover:text-white transition-colors">Về GoViet</a>
      <a href="#" class="hover:text-white transition-colors">Điều khoản</a>
      <a href="#" class="hover:text-white transition-colors">Bảo mật</a>
      <a href="#" class="hover:text-white transition-colors">Liên hệ</a>
    </div>

    <p class="text-[10px] text-white/30">© 2025 GoViet. Di chuyển xanh, sống xanh. 🌱</p>
  </div>
</section>
