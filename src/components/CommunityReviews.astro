---
const reviews = [
  {
    name: 'Minh Anh',
    avatar: '👩',
    station: 'Ga Thảo Điền',
    rating: 5,
    text: 'Quán cà phê ngay cạnh ga Thảo Điền siêu đẹp! View sông Sài Gòn, giá bình dân. Recommend mọi người ghé thử.',
    time: '2 giờ trước',
    likes: 24,
    image: null,
  },
  {
    name: 'Đức Phát',
    avatar: '👨',
    station: 'Trạm Buýt Bến Thành',
    rating: 4,
    text: 'Khu phố đi bộ Nguyễn Huệ cách trạm 5 phút đi bộ. Tối cuối tuần rất đông vui, nhiều quán ăn ngon.',
    time: '5 giờ trước',
    likes: 18,
    image: null,
  },
  {
    name: 'Thu Hà',
    avatar: '👧',
    station: 'Ga Bình Thái',
    rating: 5,
    text: 'Chợ Thủ Đức gần ga, mua đồ ăn sáng tiện lắm. Bánh mì 15k ngon xuất sắc!',
    time: '1 ngày trước',
    likes: 42,
    image: null,
  },
];
---

<section class="py-10 px-4 bg-surface">
  <div class="max-w-md mx-auto">
    <div class="text-center mb-6">
      <span class="inline-block bg-secondary/10 text-secondary text-xs font-semibold px-3 py-1 rounded-full mb-3">CỘNG ĐỒNG</span>
      <h2 class="text-2xl font-bold text-text">Review & Địa điểm hay</h2>
      <p class="text-text-muted text-sm mt-2">Khám phá địa điểm thú vị gần trạm, ga từ cộng đồng</p>
    </div>

    <div class="space-y-4">
      {reviews.map((review) => (
        <div class="bg-white rounded-2xl p-4 card-shadow">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-lg">
              {review.avatar}
            </div>
            <div class="flex-1">
              <div class="text-sm font-semibold text-text">{review.name}</div>
              <div class="text-xs text-text-muted flex items-center gap-1">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
                </svg>
                {review.station}
              </div>
            </div>
            <div class="flex gap-0.5">
              {Array.from({ length: review.rating }).map(() => (
                <svg class="w-3.5 h-3.5 text-accent" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
          </div>

          <p class="text-sm text-text leading-relaxed mb-3">{review.text}</p>

          <div class="flex items-center justify-between text-xs text-text-muted">
            <span>{review.time}</span>
            <button class="flex items-center gap-1 hover:text-red-500 transition-colors">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
              </svg>
              {review.likes}
            </button>
          </div>
        </div>
      ))}
    </div>

    <button class="w-full mt-4 py-3 text-sm font-semibold text-primary bg-primary/5 rounded-xl hover:bg-primary/10 transition-colors">
      Xem thêm review →
    </button>
  </div>
</section>
