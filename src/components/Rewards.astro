---
const rewards = [
  { icon: '☕', name: 'Trà sữa miễn phí', points: 500 },
  { icon: '🎫', name: 'Vé metro miễn phí', points: 300 },
  { icon: '🎁', name: 'Voucher GrabFood 50K', points: 800 },
];
---

<section id="rewards" class="py-10 px-4 bg-surface">
  <div class="max-w-md mx-auto">
    <div class="text-center mb-6">
      <span class="inline-block bg-accent/10 text-accent text-xs font-semibold px-3 py-1 rounded-full mb-3">TÍCH ĐIỂM</span>
      <h2 class="text-2xl font-bold text-text">Chụp vé, đổi quà</h2>
      <p class="text-text-muted text-sm mt-2">Mỗi chuyến đi là một cơ hội nhận quà</p>
    </div>

    <!-- How it works -->
    <div class="bg-white rounded-2xl p-5 card-shadow mb-4">
      <h3 class="text-sm font-bold text-text mb-4">Cách hoạt động</h3>
      <div class="flex items-start gap-3">
        <div class="flex flex-col items-center gap-1">
          <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-lg">📸</div>
          <div class="w-0.5 h-6 bg-gray-200"></div>
        </div>
        <div class="pb-6">
          <div class="text-sm font-semibold text-text">Chụp vé</div>
          <div class="text-xs text-text-muted">Chụp ảnh vé xe buýt hoặc metro</div>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <div class="flex flex-col items-center gap-1">
          <div class="w-10 h-10 rounded-full bg-secondary/10 flex items-center justify-center text-lg">⭐</div>
          <div class="w-0.5 h-6 bg-gray-200"></div>
        </div>
        <div class="pb-6">
          <div class="text-sm font-semibold text-text">Tích điểm</div>
          <div class="text-xs text-text-muted">Mỗi vé = 10-50 điểm tùy tuyến</div>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <div class="flex flex-col items-center">
          <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center text-lg">🎁</div>
        </div>
        <div>
          <div class="text-sm font-semibold text-text">Đổi quà</div>
          <div class="text-xs text-text-muted">Đổi điểm lấy voucher, vé miễn phí</div>
        </div>
      </div>
    </div>

    <!-- Rewards Grid -->
    <div class="grid grid-cols-3 gap-3">
      {rewards.map((reward) => (
        <div class="bg-white rounded-xl p-3 text-center card-shadow hover:scale-105 transition-transform cursor-pointer">
          <div class="text-2xl mb-2">{reward.icon}</div>
          <div class="text-xs font-semibold text-text mb-1">{reward.name}</div>
          <div class="text-[10px] text-accent font-bold">{reward.points} điểm</div>
        </div>
      ))}
    </div>

    <!-- Points Demo -->
    <div class="mt-4 bg-gradient-to-r from-primary to-secondary rounded-2xl p-4 text-white">
      <div class="flex items-center justify-between">
        <div>
          <div class="text-xs text-white/70">Điểm của bạn</div>
          <div class="text-2xl font-bold">1,250</div>
        </div>
        <div class="text-right">
          <div class="text-xs text-white/70">Hạng</div>
          <div class="text-sm font-bold flex items-center gap-1">
            🥇 Vàng
          </div>
        </div>
      </div>
      <div class="mt-3 bg-white/20 rounded-full h-2 overflow-hidden">
        <div class="bg-white h-full rounded-full" style="width: 65%"></div>
      </div>
      <div class="text-[10px] text-white/60 mt-1">750 điểm nữa để lên hạng Kim cương</div>
    </div>
  </div>
</section>
