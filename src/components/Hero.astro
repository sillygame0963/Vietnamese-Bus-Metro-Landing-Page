---
---

<section class="gradient-hero pt-20 pb-12 px-4 text-white relative overflow-hidden">
  <!-- Decorative circles -->
  <div class="absolute top-10 right-[-30px] w-40 h-40 rounded-full bg-white/10 floating"></div>
  <div class="absolute bottom-5 left-[-20px] w-24 h-24 rounded-full bg-white/5"></div>

  <div class="max-w-md mx-auto relative z-10">
    <div class="inline-flex items-center gap-1.5 bg-white/20 backdrop-blur-sm rounded-full px-3 py-1 text-xs font-medium mb-4">
      <span class="w-2 h-2 bg-green-300 rounded-full animate-pulse"></span>
      Hỗ trợ Metro Line 1 & 200+ tuyến buýt
    </div>

    <h1 class="text-3xl font-extrabold leading-tight mb-3">
      Di chuyển<br />thông minh<br />
      <span class="text-yellow-300">khắp Việt Nam</span>
    </h1>

    <p class="text-white/80 text-sm leading-relaxed mb-6 max-w-xs">
      Bản đồ tuyến xe buýt & metro, review cộng đồng, tích điểm đổi quà — tất cả trong một app.
    </p>

    <div class="flex gap-3">
      <a href="#download" class="bg-white text-primary font-semibold px-5 py-2.5 rounded-full text-sm hover:bg-gray-100 transition-colors flex items-center gap-2">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
        </svg>
        App Store
      </a>
      <a href="#download" class="bg-white/20 backdrop-blur-sm text-white font-semibold px-5 py-2.5 rounded-full text-sm hover:bg-white/30 transition-colors flex items-center gap-2 border border-white/30">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.198l2.807 1.626a1 1 0 010 1.73l-2.808 1.626L15.206 12l2.492-2.491zM5.864 2.658L16.802 8.99l-2.303 2.303-8.635-8.635z"/>
        </svg>
        Google Play
      </a>
    </div>

    <!-- Stats -->
    <div class="flex gap-6 mt-8 pt-6 border-t border-white/20">
      <div>
        <div class="text-xl font-bold">200+</div>
        <div class="text-white/60 text-xs">Tuyến xe buýt</div>
      </div>
      <div>
        <div class="text-xl font-bold">50K+</div>
        <div class="text-white/60 text-xs">Người dùng</div>
      </div>
      <div>
        <div class="text-xl font-bold">4.8★</div>
        <div class="text-white/60 text-xs">Đánh giá</div>
      </div>
    </div>
  </div>
</section>
