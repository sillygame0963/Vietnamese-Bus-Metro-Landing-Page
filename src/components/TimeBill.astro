---
---

<section class="py-10 px-4 bg-white">
  <div class="max-w-md mx-auto">
    <div class="text-center mb-6">
      <span class="inline-block bg-pink-100 text-pink-700 text-xs font-semibold px-3 py-1 rounded-full mb-3">CHIA SẺ</span>
      <h2 class="text-2xl font-bold text-text">Bill thời gian</h2>
      <p class="text-text-muted text-sm mt-2">Tạo "bill" chuyến đi để khoe trên social media</p>
    </div>

    <!-- Time Bill Card Preview -->
    <div class="time-bill-card rounded-2xl p-5 text-white mx-auto max-w-xs">
      <!-- Header -->
      <div class="flex items-center justify-between mb-4 pb-3 border-b border-white/10">
        <div class="flex items-center gap-2">
          <div class="w-6 h-6 rounded-md gradient-hero flex items-center justify-center">
            <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <span class="text-xs font-semibold text-white/80">GoViet Time Bill</span>
        </div>
        <span class="text-[10px] text-white/40">#GV-20250614</span>
      </div>

      <!-- Route Info -->
      <div class="space-y-3 mb-4">
        <div class="flex items-center gap-3">
          <div class="w-3 h-3 rounded-full bg-primary border-2 border-primary/30"></div>
          <div>
            <div class="text-[10px] text-white/50">ĐIỂM ĐI</div>
            <div class="text-sm font-semibold">Ga Bến Thành</div>
          </div>
          <div class="ml-auto text-xs text-white/60">07:30</div>
        </div>

        <div class="ml-1.5 border-l-2 border-dashed border-white/20 h-6 pl-5">
          <div class="text-[10px] text-white/40 flex items-center gap-1">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
            Metro Line 1 • 14 ga
          </div>
        </div>

        <div class="flex items-center gap-3">
          <div class="w-3 h-3 rounded-full bg-secondary border-2 border-secondary/30"></div>
          <div>
            <div class="text-[10px] text-white/50">ĐIỂM ĐẾN</div>
            <div class="text-sm font-semibold">Ga Suối Tiên</div>
          </div>
          <div class="ml-auto text-xs text-white/60">08:02</div>
        </div>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-3 gap-2 py-3 border-t border-b border-white/10">
        <div class="text-center">
          <div class="text-lg font-bold text-primary">32</div>
          <div class="text-[10px] text-white/50">Phút</div>
        </div>
        <div class="text-center">
          <div class="text-lg font-bold text-secondary">19.7</div>
          <div class="text-[10px] text-white/50">Km</div>
        </div>
        <div class="text-center">
          <div class="text-lg font-bold text-accent">+30</div>
          <div class="text-[10px] text-white/50">Điểm</div>
        </div>
      </div>

      <!-- Carbon Saved -->
      <div class="mt-3 flex items-center gap-2 bg-white/5 rounded-lg p-2">
        <span class="text-base">🌱</span>
        <div>
          <div class="text-[10px] text-white/60">Bạn đã giảm</div>
          <div class="text-xs font-bold text-secondary">2.4 kg CO₂</div>
        </div>
      </div>

      <!-- Share -->
      <div class="mt-4 flex items-center gap-2">
        <div class="text-[10px] text-white/40">Chia sẻ:</div>
        <div class="flex gap-2">
          <button class="w-7 h-7 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20 transition">
            <svg class="w-3.5 h-3.5 text-white/70" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </button>
          <button class="w-7 h-7 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20 transition">
            <svg class="w-3.5 h-3.5 text-white/70" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </button>
          <button class="w-7 h-7 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20 transition">
            <svg class="w-3.5 h-3.5 text-white/70" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <p class="text-center text-xs text-text-muted mt-4">
      Tự động tính thời gian di chuyển • Chia sẻ lên Facebook, Instagram, X
    </p>
  </div>
</section>
