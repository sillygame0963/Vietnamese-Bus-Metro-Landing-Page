---
---

<section id="map" class="py-10 px-4 bg-white">
  <div class="max-w-md mx-auto">
    <div class="text-center mb-6">
      <span class="inline-block bg-primary/10 text-primary text-xs font-semibold px-3 py-1 rounded-full mb-3">BẢN ĐỒ TUYẾN</span>
      <h2 class="text-2xl font-bold text-text">Tìm tuyến đi mọi nơi</h2>
      <p class="text-text-muted text-sm mt-2">Xem bản đồ tuyến xe buýt & metro trên toàn thành phố</p>
    </div>

    <!-- Map Container -->
    <div class="rounded-2xl overflow-hidden card-shadow border border-gray-100">
      <div id="route-map" class="w-full h-64 bg-gray-100"></div>

      <!-- Route Quick Select -->
      <div class="p-4 space-y-3">
        <div class="flex gap-2 overflow-x-auto pb-2 scrollbar-hide">
          <button class="shrink-0 bg-primary text-white text-xs font-medium px-3 py-1.5 rounded-full">Metro Line 1</button>
          <button class="shrink-0 bg-gray-100 text-text-muted text-xs font-medium px-3 py-1.5 rounded-full hover:bg-gray-200 transition">Buýt 01</button>
          <button class="shrink-0 bg-gray-100 text-text-muted text-xs font-medium px-3 py-1.5 rounded-full hover:bg-gray-200 transition">Buýt 19</button>
          <button class="shrink-0 bg-gray-100 text-text-muted text-xs font-medium px-3 py-1.5 rounded-full hover:bg-gray-200 transition">Buýt 36</button>
          <button class="shrink-0 bg-gray-100 text-text-muted text-xs font-medium px-3 py-1.5 rounded-full hover:bg-gray-200 transition">Buýt 52</button>
        </div>

        <!-- Sample Route Info -->
        <div class="bg-surface rounded-xl p-3 flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0020 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <div class="text-sm font-semibold text-text">Metro Line 1</div>
            <div class="text-xs text-text-muted truncate">Bến Thành → Suối Tiên • 14 ga</div>
          </div>
          <div class="text-right shrink-0">
            <div class="text-xs font-semibold text-secondary">19.7 km</div>
            <div class="text-xs text-text-muted">~30 phút</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  async function initMap() {
    const L = await import('leaflet');

    const map = L.map('route-map', {
      zoomControl: false,
      attributionControl: false,
    }).setView([10.7769, 106.7009], 13);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 18,
    }).addTo(map);

    // Metro Line 1 route (simplified)
    const metroLine = [
      [10.7731, 106.6980], // Bến Thành
      [10.7820, 106.6990], // Nhà hát TP
      [10.7900, 106.7050], // Ba Son
      [10.8010, 106.7140], // Văn Thánh
      [10.8120, 106.7210], // Tân Cảng
      [10.8200, 106.7290], // Thảo Điền
      [10.8290, 106.7380], // An Phú
      [10.8380, 106.7500], // Rạch Chiếc
      [10.8450, 106.7610], // Phước Long
      [10.8530, 106.7720], // Bình Thái
      [10.8600, 106.7830], // Thủ Đức
      [10.8700, 106.7950], // HT Công nghệ cao
      [10.8790, 106.8060], // Đại học QG
      [10.8880, 106.8190], // Suối Tiên
    ];

    L.polyline(metroLine, {
      color: '#0ea5e9',
      weight: 4,
      opacity: 0.9,
    }).addTo(map);

    // Station markers
    const stations = [
      { pos: [10.7731, 106.6980], name: 'Bến Thành' },
      { pos: [10.8200, 106.7290], name: 'Thảo Điền' },
      { pos: [10.8600, 106.7830], name: 'Thủ Đức' },
      { pos: [10.8880, 106.8190], name: 'Suối Tiên' },
    ];

    stations.forEach(s => {
      L.circleMarker(s.pos as [number, number], {
        radius: 6,
        color: '#0ea5e9',
        fillColor: '#fff',
        fillOpacity: 1,
        weight: 3,
      }).addTo(map).bindPopup(`<b>${s.name}</b>`);
    });
  }

  initMap();
</script>
